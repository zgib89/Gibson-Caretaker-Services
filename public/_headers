# Headers for Cloudflare Workers Static Assets.
# These apply to the real pages (the Worker's ASSETS.fetch wrapping is a no-op — assets serve first).

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=15552000
  # CSP runs in Report-Only first so it can never break the page or the (CF Analytics) beacon.
  # After confirming no violations in production, this can be promoted to Content-Security-Policy.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://cloudflareinsights.com https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Long-cache the immutable image assets (heavy, never change without a new filename)
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

# HTML always revalidates so content edits go live immediately
/index.html
  Cache-Control: public, max-age=0, must-revalidate
